<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Acces a la localisation precise (requis pour injecter des positions fictives) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Autorisation de position fictive (a activer aussi dans Options developpeur) -->
    <uses-permission android:name="android.permission.ACCESS_MOCK_LOCATION" />
    <!-- Requis pour les services en premier plan -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Requis sur Android 14+ pour les services de localisation en premier plan -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.FGPS"
        android:allowBackup="true">

        <!-- Activite de lancement : affiche les instructions de configuration -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Service de simulation GPS tourne en premier plan -->
        <service
            android:name=".MockLocationService"
            android:foregroundServiceType="location"
            android:exported="false" />

        <!-- Fournisseur du widget ON/OFF -->
        <receiver
            android:name=".GpsWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.fgps.TOGGLE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

    </application>

</manifest>
