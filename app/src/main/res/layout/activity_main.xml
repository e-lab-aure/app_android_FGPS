<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FGPS"
        android:textColor="#FFFFFF"
        android:textSize="48sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fake GPS"
        android:textColor="#884CAF50"
        android:textSize="16sp"
        android:layout_marginBottom="32dp" />

    <!-- Statut de la permission de localisation -->
    <TextView
        android:id="@+id/tv_permission_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Permission localisation : requise"
        android:textColor="#FFFF5722"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Bouton accorder la permission (masque si deja accordee) -->
    <Button
        android:id="@+id/btn_grant_permission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Accorder la permission de localisation"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF5722"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Configuration requise"
        android:textColor="#CCFFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1.  Accordez la permission ci-dessus\n\n2.  Activez les Options developpeur\n    (Parametres > A propos > taper 7x sur le numero de build)\n\n3.  Appuyez sur le bouton ci-dessous\n    puis selectionnez FGPS comme\n    Application de position fictive\n\n4.  Ajoutez le widget FGPS sur votre ecran d&#8217;accueil\n\n5.  Appuyez sur le widget pour activer / desactiver"
        android:textColor="#AAFFFFFF"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="32dp" />

    <!-- Raccourci direct vers les Options developpeur -->
    <Button
        android:id="@+id/btn_open_dev_options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ouvrir les Options developpeur"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50" />

</LinearLayout>
